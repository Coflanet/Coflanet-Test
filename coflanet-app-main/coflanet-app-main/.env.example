# ============================================
# Coflanet .env 설정 파일 템플릿
# ============================================
# 이 파일은 .env 작성 + GitHub Secrets 등록 시 참고용입니다.
# 주의: .env 파일에는 # 주석을 넣지 마세요 (Xcode 빌드 에러 발생)
# 상세 가이드: docs/CI_CD_SETUP.md
#
# [앱 환경 변수] — .env에 값 입력 + 동일한 값을 GitHub Secrets에도 등록
#   → .env: 로컬 개발 시 flutter run에서 사용
#   → GitHub Secrets: CI/CD에서 .env 파일을 동적 생성할 때 사용
#   → 같은 값이 양쪽에 있어야 로컬과 CI 빌드가 동일하게 동작
#
# [CI/CD 전용] — GitHub Secrets에만 등록 (로컬에서 사용하지 않음)
#   → 코드 사이닝, 스토어 배포 등 CI 환경에서만 필요한 값
#   → .env에 넣을 필요 없음, 여기에 참고용으로만 기재

# =====================
# [앱 환경 변수]
# =====================

# --- 네이버 로그인 (네이티브 SDK) ---
# Supabase 미지원 → 네이티브 SDK 필수
# 사용처: AndroidManifest.xml, Info.plist, NaverAuthProvider
# 발급: https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 카카오 로그인 (URL scheme) ---
# Supabase OAuth를 사용하지만, AndroidManifest/Info.plist에 kakao{KEY}://oauth scheme이 등록됨
# 네이티브 SDK 제거 전까지 빌드 시 필요
# 사용처: AndroidManifest.xml, Info.plist, KakaoSdk.init()
# 발급: https://developers.kakao.com/console/app
KAKAO_NATIVE_APP_KEY=

# --- Supabase ---
# 사용처: Supabase.initialize() (Auth, RPC, Edge Functions 전체)
# 발급: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# =====================
# [CI/CD 전용] GitHub Secrets에만 등록
# =====================

# --- Android 코드 사이닝 ---
# release.yml에서 signed APK/AAB 빌드 시 사용
# 미등록 시 debug 키로 fallback (스토어 업로드 불가)
# 생성: keytool -genkeypair -alias coflanet -keyalg RSA -keysize 2048 -validity 10000 -keystore coflanet.jks
# ANDROID_KEYSTORE_BASE64=   # base64 -i coflanet.jks | pbcopy
# ANDROID_KEY_ALIAS=         # coflanet
# ANDROID_KEY_PASSWORD=      # 키 비밀번호
# ANDROID_STORE_PASSWORD=    # 스토어 비밀번호

# --- iOS 코드 사이닝 ---
# release.yml에서 signed IPA 빌드 시 사용
# 미등록 시 --no-codesign fallback (스토어 업로드 불가)
# IOS_CERTIFICATE_BASE64=          # base64 -i distribution.p12 | pbcopy
# IOS_CERTIFICATE_PASSWORD=        # .p12 export 시 설정한 비밀번호
# IOS_PROVISION_PROFILE_BASE64=    # base64 -i profile.mobileprovision | pbcopy

# --- App Store Connect API Key ---
# deploy.yml에서 TestFlight 업로드 시 사용
# 발급: https://appstoreconnect.apple.com/access/integrations/api
# APP_STORE_CONNECT_API_KEY_ID=       # Key ID (예: 9H7TKR68G4)
# APP_STORE_CONNECT_ISSUER_ID=        # Issuer ID (예: 964d25ea-...)
# APP_STORE_CONNECT_API_KEY_BASE64=   # base64 -i AuthKey_XXX.p8 | pbcopy

# --- Google Play 서비스 계정 ---
# deploy.yml에서 Google Play 업로드 시 사용
# 발급: Google Cloud Console → Service Accounts → JSON key
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=   # JSON 파일 전체 내용 (base64 아님)
